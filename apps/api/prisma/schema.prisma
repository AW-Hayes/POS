generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants & Locations ─────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations            Location[]
  users                User[]
  products             Product[]
  categories           Category[]
  customers            Customer[]
  attributeDefinitions AttributeDefinition[]
  vendors              Vendor[]
  promotions           Promotion[]
  priceLevels          PriceLevel[]
  giftCards            GiftCard[]
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  settings  Json     @default("{}")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registers      Register[]
  inventory      InventoryItem[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
}

model Register {
  id         String   @id @default(cuid())
  locationId String
  name       String
  mode       String   @default("desktop") // "touch" | "desktop"
  settings   Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sessions RegisterSession[]
}

model RegisterSession {
  id           String    @id @default(cuid())
  registerId   String
  userId       String
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingCash  Float     @default(0)
  closingCash  Float?
  expectedCash Float?
  closingNotes String?
  notes        String?

  register  Register   @relation(fields: [registerId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
  orders    Order[]
  cashDrops CashDrop[]
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String?
  pin          String?
  role         String   @default("cashier")
  commissionRate Float?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions             RegisterSession[]
  orders               Order[]
  salespersonOrders    Order[]               @relation("Salesperson")
  inventoryAdjustments InventoryAdjustment[]
  purchaseOrders       PurchaseOrder[]
  orderReturns         OrderReturn[]
  layawayDeposits      LayawayDeposit[]
  cashDrops            CashDrop[]
  loyaltyTransactions  LoyaltyTransaction[]
  timeEntries          TimeEntry[]

  @@unique([tenantId, email])
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  color     String?
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model AttributeDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  values    String[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productAttributes ProductAttribute[]

  @@unique([tenantId, name])
}

model Product {
  id             String   @id @default(cuid())
  tenantId       String
  categoryId     String?
  name           String
  description    String?
  sku            String?
  barcode        String?
  price          Float
  cost           Float?
  taxable                 Boolean  @default(true)
  trackInventory          Boolean  @default(true)
  active                  Boolean  @default(true)
  imageUrl                String?
  sortOrder               Int      @default(0)
  requiresAgeVerification Boolean  @default(false)
  minAge                  Int?
  preferredVendorId       String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           Category?            @relation(fields: [categoryId], references: [id])
  attributes         ProductAttribute[]
  variants           ProductVariant[]
  inventory          InventoryItem[]
  prices             ProductPrice[]
  purchaseOrderItems PurchaseOrderItem[]
  preferredVendor    Vendor?              @relation("PreferredVendor", fields: [preferredVendorId], references: [id])
  serialNumbers      SerialNumber[]
  priceBreaks        PriceBreak[]
  bundleComponents   BundleComponent[]    @relation("BundleProduct")
  appearsInBundles   BundleComponent[]    @relation("ComponentProduct")

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
}

model ProductAttribute {
  id          String @id @default(cuid())
  productId   String
  attributeId String

  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute     AttributeDefinition @relation(fields: [attributeId], references: [id])
  variantValues VariantAttributeValue[]

  @@unique([productId, attributeId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  sku       String?
  barcode   String?
  price     Float?
  cost      Float?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product            Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues    VariantAttributeValue[]
  inventory          InventoryItem[]
  orderItems         OrderItem[]
  prices             ProductPrice[]
  purchaseOrderItems PurchaseOrderItem[]
  priceBreaks        PriceBreak[]
  serialNumbers      SerialNumber[]
}

model VariantAttributeValue {
  id                 String @id @default(cuid())
  variantId          String
  productAttributeId String
  value              String

  variant          ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productAttribute ProductAttribute @relation(fields: [productAttributeId], references: [id], onDelete: Cascade)

  @@unique([variantId, productAttributeId])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id         String   @id @default(cuid())
  locationId String
  productId  String
  variantId  String?
  quantity     Float    @default(0)
  lowStockAt   Float?
  reorderPoint Float?
  reorderQty   Float?
  binLocation  String?
  updatedAt    DateTime @updatedAt

  location    Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant?       @relation(fields: [variantId], references: [id])
  adjustments InventoryAdjustment[]

  @@unique([locationId, productId, variantId])
}

model InventoryAdjustment {
  id              String   @id @default(cuid())
  inventoryItemId String
  userId          String?
  type            String
  delta           Float
  quantityAfter   Float
  note            String?
  reference       String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  email                String?
  phone                String?
  notes                String?
  taxExempt            Boolean  @default(false)
  taxExemptCertificate String?
  priceLevelId         String?
  loyaltyPoints        Float    @default(0)
  arBalance            Float    @default(0)
  creditLimit          Float?
  emailReceiptsEnabled Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders              Order[]
  priceLevel          PriceLevel?          @relation(fields: [priceLevelId], references: [id])
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([tenantId, email])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                String    @id @default(cuid())
  tenantId          String
  locationId        String
  sessionId         String?
  userId            String
  customerId        String?
  status            String    @default("open") // open|completed|voided|refunded|held|estimate|layaway
  subtotal          Float
  taxAmount         Float     @default(0)
  discountAmount    Float     @default(0)
  promotionDiscount Float     @default(0)
  total             Float
  notes             String?
  heldName          String?
  estimateExpiresAt DateTime?
  salespersonId     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  location        Location         @relation(fields: [locationId], references: [id])
  session         RegisterSession? @relation(fields: [sessionId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  salesperson     User?            @relation("Salesperson", fields: [salespersonId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  returns         OrderReturn[]
  layawayDeposits LayawayDeposit[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  name      String
  sku       String?
  price     Float
  quantity  Float
  discount  Float   @default(0)
  taxRate   Float   @default(0)
  total     Float

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  returnItems OrderReturnItem[]
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  method     String // "cash" | "card" | "store_credit" | "gift_card" | "other"
  amount     Float
  reference  String?
  giftCardId String?
  createdAt  DateTime @default(now())

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giftCard GiftCard? @relation(fields: [giftCardId], references: [id])
}

// ─── Returns ──────────────────────────────────────────────────────────────────

model OrderReturn {
  id        String   @id @default(cuid())
  orderId   String
  userId    String?
  reason    String?
  subtotal  Float    @default(0)
  taxAmount Float    @default(0)
  total     Float    @default(0)
  createdAt DateTime @default(now())

  order   Order             @relation(fields: [orderId], references: [id])
  user    User?             @relation(fields: [userId], references: [id])
  items   OrderReturnItem[]
  refunds ReturnRefund[]

  @@index([orderId])
}

model OrderReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  orderItemId String
  quantity    Float
  price       Float
  taxRate     Float   @default(0)
  total       Float

  return    OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem   @relation(fields: [orderItemId], references: [id])
}

model ReturnRefund {
  id        String   @id @default(cuid())
  returnId  String
  method    String // "cash" | "card" | "store_credit" | "gift_card"
  amount    Float
  reference String?
  createdAt DateTime @default(now())

  return OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

// ─── Promotions ───────────────────────────────────────────────────────────────

model Promotion {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        String    // "percent_off" | "fixed_off" | "bogo" | "price_override"
  value       Float     // % or $ amount
  minQty      Int?
  minAmount   Float?
  productIds  String[]
  categoryIds String[]
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Price Levels ─────────────────────────────────────────────────────────────

model PriceLevel {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  discount    Float   @default(0) // % off retail as fallback

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
  prices    ProductPrice[]

  @@unique([tenantId, name])
}

model ProductPrice {
  id           String  @id @default(cuid())
  priceLevelId String
  productId    String
  variantId    String?
  price        Float

  priceLevel PriceLevel     @relation(fields: [priceLevelId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([priceLevelId, productId, variantId])
}

// ─── Vendors & Purchase Orders ────────────────────────────────────────────────

model Vendor {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  email     String?
  phone     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders    PurchaseOrder[]
  preferredProducts Product[]   @relation("PreferredVendor")

  @@index([tenantId])
}

model PurchaseOrder {
  id         String    @id @default(cuid())
  tenantId   String
  locationId String
  vendorId   String?
  userId     String?
  status     String    @default("draft") // "draft"|"ordered"|"partial"|"received"|"cancelled"
  notes      String?
  total      Float     @default(0)
  orderedAt  DateTime?
  receivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  location Location            @relation(fields: [locationId], references: [id])
  vendor   Vendor?             @relation(fields: [vendorId], references: [id])
  user     User?               @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]

  @@index([tenantId])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  variantId       String?
  orderedQty      Int
  receivedQty     Int     @default(0)
  unitCost        Float
  total           Float

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
}

// ─── Gift Cards ───────────────────────────────────────────────────────────────

model GiftCard {
  id             String    @id @default(cuid())
  tenantId       String
  code           String    @unique
  balance        Float
  initialBalance Float
  active         Boolean   @default(true)
  expiresAt      DateTime?
  issuedAt       DateTime  @default(now())

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions GiftCardTransaction[]
  payments     Payment[]

  @@index([tenantId])
  @@index([code])
}

model GiftCardTransaction {
  id           String   @id @default(cuid())
  giftCardId   String
  orderId      String?
  type         String   // "issue" | "redeem" | "reload" | "void"
  amount       Float
  balanceAfter Float
  note         String?
  createdAt    DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id])

  @@index([giftCardId])
}

// ─── Layaway Deposits ─────────────────────────────────────────────────────────

model LayawayDeposit {
  id        String   @id @default(cuid())
  orderId   String
  userId    String?
  amount    Float
  method    String   // "cash" | "card" | "store_credit" | "gift_card" | "other"
  reference String?
  note      String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([orderId])
}

// ─── Cash Drops ───────────────────────────────────────────────────────────────

model CashDrop {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  type      String   @default("drop") // "drop" | "paid_in" | "paid_out"
  amount    Float
  reason    String?
  note      String?
  createdAt DateTime @default(now())

  session RegisterSession @relation(fields: [sessionId], references: [id])
  user    User            @relation(fields: [userId], references: [id])

  @@index([sessionId])
}

// ─── Loyalty ──────────────────────────────────────────────────────────────────

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  userId     String?
  orderId    String?
  type       String   // "earn" | "redeem" | "adjust" | "expire"
  points     Float
  note       String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([customerId])
}

// ─── Price Breaks ─────────────────────────────────────────────────────────────

model PriceBreak {
  id        String  @id @default(cuid())
  productId String
  variantId String?
  minQty    Float
  price     Float

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
}

// ─── Serial Numbers ───────────────────────────────────────────────────────────

model SerialNumber {
  id              String    @id @default(cuid())
  productId       String
  variantId       String?
  serial          String
  status          String    @default("available") // "available" | "sold" | "returned"
  orderItemId     String?
  purchaseOrderId String?
  createdAt       DateTime  @default(now())
  soldAt          DateTime?

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([productId, serial])
  @@index([productId])
}

// ─── Cycle Counts ────────────────────────────────────────────────────────────

model CycleCount {
  id         String    @id @default(cuid())
  tenantId   String
  locationId String
  name       String
  status     String    @default("open") // "open" | "closed"
  startedAt  DateTime  @default(now())
  closedAt   DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items CycleCountItem[]

  @@index([tenantId])
  @@index([locationId])
}

model CycleCountItem {
  id           String    @id @default(cuid())
  cycleCountId String
  productId    String
  variantId    String?
  expectedQty  Float
  countedQty   Float?
  countedAt    DateTime?
  note         String?

  cycleCount CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)

  @@unique([cycleCountId, productId, variantId])
}

// ─── Service Tickets ─────────────────────────────────────────────────────────

model ServiceTicket {
  id          String    @id @default(cuid())
  tenantId    String
  locationId  String
  customerId  String?
  ticketNumber String?
  status      String    @default("open") // "open" | "in_progress" | "ready" | "completed" | "cancelled"
  description String?
  techNotes   String?
  estimatedCost Float?
  finalCost   Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  items ServiceTicketItem[]

  @@index([tenantId])
  @@index([locationId])
}

model ServiceTicketItem {
  id              String  @id @default(cuid())
  serviceTicketId String
  type            String  // "labor" | "part"
  name            String
  productId       String?
  variantId       String?
  quantity        Float   @default(1)
  unitPrice       Float
  total           Float

  serviceTicket ServiceTicket @relation(fields: [serviceTicketId], references: [id], onDelete: Cascade)
}

// ─── Product Bundles ──────────────────────────────────────────────────────────

model BundleComponent {
  id               String  @id @default(cuid())
  bundleProductId  String
  componentProductId String
  componentVariantId String?
  quantity         Float   @default(1)

  bundleProduct    Product @relation("BundleProduct",    fields: [bundleProductId],    references: [id], onDelete: Cascade)
  componentProduct Product @relation("ComponentProduct", fields: [componentProductId], references: [id])

  @@unique([bundleProductId, componentProductId, componentVariantId])
  @@index([bundleProductId])
}

// ─── Time Clock ───────────────────────────────────────────────────────────────

model TimeEntry {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  type       String    @default("work") // "work" | "break"
  clockIn    DateTime
  clockOut   DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}
